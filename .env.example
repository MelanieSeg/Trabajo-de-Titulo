FRONTEND_PORT=8081
BACKEND_PORT=8000
POSTGRES_PORT=5432
VITE_API_BASE_URL=/api
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,https://localhost:8081,https://127.0.0.1:8081
ETL_UPLOAD_DIR=/app/data/uploads
SAMPLE_CSV_PATH=/app/data/raw/sample_consumption.csv
PLATFORM_CONFIG_PATH=/opt/ecoenergy/app/platform-config.json

# Email Configuration (for password reset)
# For Gmail: Use app-specific password (https://myaccount.google.com/apppasswords)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ecoenergy.com
EMAIL_FROM_NAME=EcoEnergy
RESET_PASSWORD_TOKEN_EXPIRE_HOURS=1
