APP_NAME=EcoEnergy API
APP_ENV=development
APP_VERSION=1.0.0
DATABASE_URL=postgresql+psycopg2://eco_user:eco_pass@db:5432/eco_energy
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,https://localhost:8080,https://127.0.0.1:8080,https://localhost:8081,https://127.0.0.1:8081
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With
CORS_EXPOSE_HEADERS=Content-Length,Content-Type
ETL_UPLOAD_DIR=/app/data/uploads
SAMPLE_CSV_PATH=/app/data/raw/sample_consumption.csv
PLATFORM_CONFIG_PATH=../app/platform-config.json
DEFAULT_COMPANY_NAME=Green Glow Industries
DEFAULT_ALERT_ELECTRICITY_THRESHOLD_PCT=20
DEFAULT_ALERT_WATER_THRESHOLD_PCT=18
DEFAULT_ALERT_VOLATILITY_THRESHOLD_PCT=15
